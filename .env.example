TZ=Europe/Helsinki

PUID=1000
PGID=1000

ZIGBEE_ADAPTER=/dev/serial/by-id/usb-Itead_Sonoff_Zigbee_3.0_USB_Dongle_Plus_V2_3ceab1a77991f011a410b47629b3d7e9-if00-port0

# MQTT credentials — used by Z2M, Telegraf, and your HA VM.
# The mosquitto passwd file is generated from THESE values (see setup notes).
MQTT_USER=
MQTT_PASSWORD=

# Created on first boot — these now matter
INFLUXDB_INIT_USERNAME=
INFLUXDB_INIT_PASSWORD=
INFLUXDB_INIT_ORG=
INFLUXDB_INIT_BUCKET=
INFLUXDB_INIT_TOKEN=

GRAFANA_ADMIN_PASSWORD=

# Telegraf target bucket (optional; defaults to "telegraf" if unset).
# Create this bucket in InfluxDB before starting Telegraf — see notes.
TELEGRAF_BUCKET=telegraf

CF_DDNS_API_TOKEN=
